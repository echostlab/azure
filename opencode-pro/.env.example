# OpenCode Pro — Environment Variables
# Copy this file to .env and fill in the values.

# === Required ===

# GitHub App credentials
APP_ID=12345
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
WEBHOOK_SECRET=your_webhook_secret_here

# Primary LLM provider (used when no per-repo config is found)
# Format: "provider/model-name" e.g. "openai/gpt-4o"
PRIMARY_MODEL=openai/gpt-4o

# === Provider API Keys ===
# Set the keys for the providers you intend to use.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_RESOURCE_NAME=my-resource
OPENROUTER_API_KEY=sk-or-...

# === Optional ===

# Small model for quick classifications, trigger detection, etc.
# Falls back to PRIMARY_MODEL if not set.
SMALL_MODEL=openai/gpt-4o-mini

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Max context tokens for PR reviews
MAX_CONTEXT_TOKENS=128000